{
  "name": "pi-context",
  "version": "0.1.0",
  "description": "Tool result processing, distillation, and context management for pi-coding-agent",
  "main": "index.ts",
  "types": "index.ts",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pi-atelier/shared-utils": "file:../pi-shared-utils"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  },
  "pi": {
    "extensions": [
      "."
    ]
  },
  "keywords": [
    "pi-package"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=1.0.0",
    "@earendil-works/pi-tui": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "files": [
    "*.ts",
    "tests/",
    "README.md",
    "tsconfig.json",
    "vitest.config.ts",
    "package.json"
  ]
}
